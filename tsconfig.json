{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "resolvePackageJsonExports": false,
    "typeRoots": ["./node_modules/@types"],
    "paths": {
      "@/*": ["./*"]
    }
  },
  "include": ["**/*.ts", "**/*.tsx", ".expo/types/**/*.ts", "expo-env.d.ts"],
  "exclude": ["node_modules", "supabase/functions"]
}
