# --- Supabase (Expo: EXPO_PUBLIC_ prefix for client) ---
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# Deep linking / OAuth callback base (e.g. https://yourapp.com or exp://...)
# Email confirmation + password reset use the same redirect — add linkup://auth/callback in Supabase → Auth → URL Configuration.
# Reset email template + spam: see docs/PASSWORD_RESET_EMAIL_SETUP.md (paste supabase/email-templates/recovery.html in Dashboard).
EXPO_PUBLIC_URL=

# OAuth redirect URL — must exactly match Supabase Dashboard → Authentication → URL Configuration → Redirect URLs.
# Real devices cannot use localhost. Prefer leaving this empty: the app uses linkup://auth/callback (see app.json "scheme").
# If you set a URL here, never use http://localhost:8081 for native builds — Google will open that on the phone and fail.
# Add to Supabase redirect list: linkup://auth/callback (and your Supabase Site URL if needed).
EXPO_PUBLIC_AUTH_REDIRECT_URL=

# Google Cloud OAuth client IDs (optional in the app when using Supabase-hosted Google OAuth).
# Configure the same Web client in Supabase → Authentication → Providers → Google (Client ID + Secret live in Supabase).
# Use these if you later add native @react-native-google-signin / pass id_token to Supabase.
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=

# Phone OTP — when users omit +country, prepend this E.164 prefix (e.g. +234 for Nigeria, +1 for US).
EXPO_PUBLIC_PHONE_DEFAULT_DIAL_CODE=+1

# Optional hint string for the phone field (shown in UI).
EXPO_PUBLIC_PHONE_FORMAT_HINT=

# Optional label under phone signup (e.g. explains Twilio is configured in Supabase, not in the app).
EXPO_PUBLIC_PHONE_SMS_PROVIDER_LABEL=Twilio (via Supabase)

# --- Twilio (do NOT use EXPO_PUBLIC_ for secrets — they must not ship in the app) ---
# The app uses Supabase Phone Auth; you paste these into Supabase Dashboard → Authentication → Providers → Phone.
# Keep the same names here for team reference, CI, or Supabase Edge Function secrets — not for the Expo client runtime.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# Messaging Service SID (SMS) — Supabase Phone provider typically asks for this when using Twilio.
TWILIO_MESSAGE_SERVICE_SID=
# Optional: Verify API Service SID if you build a custom backend (not used by default Expo flow).
TWILIO_VERIFY_SERVICE_SID=

# MessageBird (server / Supabase Dashboard only — never EXPO_PUBLIC_)
MESSAGEBIRD_API_KEY=
MESSAGEBIRD_ORIGINATOR=

# Server-side only — never ship PAYSTACK_SECRET_KEY in the mobile app.
PAYSTACK_SECRET_KEY=
EXPO_PUBLIC_PAYSTACK_PUBLIC_KEY=

# AI: OpenAI-compatible or your moderation provider (Edge Function recommended).
AI_VERIFICATION_KEY=

# --- Google Maps Platform (three API keys — restrict each in Google Cloud) ---
# Credentials → Create credentials → API key. Do not commit real values to git.
# Android: Maps SDK for Android + package com.linkup.app + SHA-1 → app.config.js injects into native build.
EXPO_PUBLIC_GOOGLE_MAPS_ANDROID_API_KEY=
# iOS: Maps SDK for iOS + bundle com.linkup.app
EXPO_PUBLIC_GOOGLE_MAPS_IOS_API_KEY=
# Web (Expo web): Maps JavaScript API + HTTP referrer restrictions
EXPO_PUBLIC_GOOGLE_MAPS_WEB_API_KEY=
# Optional: note your debug/release SHA-1 for Android key setup (reference only)
# ANDROID_GOOGLE_CERTIFICATE_HASH=

# Optional extras
EXPO_PUBLIC_SENTRY_DSN=
OTHER_API_KEYS=

# Legacy aliases (some tools expect these names — mirror EXPO_PUBLIC_* for Supabase)
SUPABASE_URL=
SUPABASE_ANON_KEY=