{
  "name": "linkup",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "postinstall": "patch-package",
    "start": "expo start --dev-client",
    "start:clear": "expo start --dev-client --clear",
    "android": "expo run:android",
    "android:usb": "adb reverse tcp:8081 tcp:8081 && expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "lint": "expo lint",
    "eas:verify-install": "npm ci --include=dev",
    "supabase:deploy-push": "npx supabase functions deploy push-on-notification --no-verify-jwt && npx supabase functions deploy test-expo-push --no-verify-jwt"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.2",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/datetimepicker": "8.6.0",
    "@react-native-community/slider": "5.1.2",
    "@supabase/supabase-js": "^2.49.1",
    "expo": "~55.0.12",
    "expo-auth-session": "~55.0.12",
    "expo-calendar": "~55.0.14",
    "expo-camera": "~55.0.14",
    "expo-clipboard": "~55.0.13",
    "expo-constants": "~55.0.12",
    "expo-dev-client": "~55.0.32",
    "expo-file-system": "~55.0.15",
    "expo-font": "~55.0.6",
    "expo-haptics": "~55.0.14",
    "expo-image": "~55.0.8",
    "expo-image-manipulator": "~55.0.15",
    "expo-image-picker": "~55.0.17",
    "expo-linear-gradient": "~55.0.12",
    "expo-linking": "~55.0.11",
    "expo-location": "~55.1.7",
    "expo-notifications": "^0.32.16",
    "expo-router": "~55.0.11",
    "expo-secure-store": "~55.0.12",
    "expo-splash-screen": "~55.0.16",
    "expo-status-bar": "~55.0.5",
    "expo-video": "~55.0.15",
    "expo-web-browser": "~55.0.13",
    "moti": "^0.30.0",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.4",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-reanimated": "~4.2.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-web": "~0.21.0",
    "react-native-webview": "13.16.0",
    "react-native-worklets": "0.7.2"
  },
  "devDependencies": {
    "@babel/core": "^7.25.0",
    "@types/react": "~19.2.0",
    "@types/react-dom": "~19.2.0",
    "babel-plugin-module-resolver": "^5.0.0",
    "eslint": "^8.57.0",
    "eslint-config-expo": "~55.0.0",
    "patch-package": "^8.0.1",
    "typescript": "~5.9.2"
  }
}
